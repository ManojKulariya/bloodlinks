		          $('#exam_name').prop('disabled',false);
		          $('#exam_short_name').prop('disabled',false);
		          $('#btn_add_exam').html('Save').prop('disabled',false);
		        },
		        complete:function(status,xhr){
		        	if($('#_exam').val()==''){
						$('#form_exam')[0].reset();
		        	}
		        }
