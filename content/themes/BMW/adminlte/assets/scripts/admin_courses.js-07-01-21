		        },
		        error: function( jqXhr ) {
		          //alert(jqXhr)
		          if( jqXhr.status == 400 ) {
		              Swal.fire({
		                icon: 'error',
		                title: 'Request url not found',
		                confirmButtonText:'Close',
		                confirmButtonColor:'#d33',
		                allowOutsideClick: false,
		              });
		              window.location.reload();
		          }else if( jqXhr.status == 403 ) {
		              Swal.fire({
		                icon: 'error',
		                title: 'Request is forbidden',
