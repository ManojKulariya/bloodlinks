		$('#examsModal').on('show.bs.modal', function() {
			var _exam=$('#examsModal').find('#_exam').val();
		    $.ajax({
		    	type:'POST',
		    	url:base_url+'/streams/get_streams',
		    	data:{csrf_test_name:csrf_hash,_exam:_exam},
		    	success:function(d){
